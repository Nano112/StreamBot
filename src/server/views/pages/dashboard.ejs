// --- Logs ---
let logTotal = 0;
let logsActive = false;
let logPollTimer;

function startLogPolling() {
	if (logsActive) return;
	logsActive = true;
	fetchLogs();
	logPollTimer = setInterval(fetchLogs, 2000);
}

function stopLogPolling() {
	logsActive = false;
	if (logPollTimer) clearInterval(logPollTimer);
}

function getLevelColor(level) {
	if (level.includes('error')) return '#f44747';
	if (level.includes('warn')) return '#cca700';
	if (level.includes('info')) return '#6a9955';
	if (level.includes('debug')) return '#569cd6';
	return '#d4d4d4';
}

async function fetchLogs() {
	try {
		const res = await fetch(`/api/bot/logs?since=${logTotal}`);
		if (!res.ok) return;
		const data = await res.json();
		if (data.logs.length === 0) return;

		const output = document.getElementById('logsOutput');
		const autoScroll = document.getElementById('autoScrollCheck').checked;

		data.logs.forEach(entry => {
			const line = document.createElement('div');
			const color = getLevelColor(entry.level);
			line.innerHTML = `<span style="color:#858585">[${escapeHtml(entry.timestamp)}]</span> <span style="color:${color}">${escapeHtml(entry.level)}</span>: ${escapeHtml(entry.message)}`;
			output.appendChild(line);
		});

		logTotal = data.total;

		while (output.children.length > 500) {
			output.removeChild(output.firstChild);
		}

		if (autoScroll) {
			output.scrollTop = output.scrollHeight;
		}
	} catch (e) {
		// ignore
	}
}

function clearLogsView() {
	const output = document.getElementById('logsOutput');
	output.innerHTML = '';
}

// Start/stop log polling based on tab visibility
document.getElementById('logs-tab')?.addEventListener('shown.bs.tab', startLogPolling);
document.getElementById('logs-tab')?.addEventListener('hidden.bs.tab', stopLogPolling);

// --- VC History ---
async function loadVCHistory() {
	try {
		const res = await fetch('/api/bot/vc-history');
		if (!res.ok) return;
		const data = await res.json();
		const container = document.getElementById('vcHistoryContainer');
		const list = document.getElementById('vcHistoryList');
		if (!data.entries || data.entries.length === 0) {
			container.style.display = 'none';
			return;
		}
		container.style.display = '';
		list.innerHTML = data.entries.map(e => {
			const icon = e.guildIcon
				? `<img src="${escapeHtml(e.guildIcon)}" width="16" height="16" class="rounded-circle me-1" style="object-fit:cover;" onerror="this.style.display='none'">`
				: '<i class="fas fa-server me-1" style="font-size:12px;"></i>';
			return `<button class="btn btn-outline-secondary btn-sm d-flex align-items-center"
				onclick="quickJoinVC('${escapeHtml(e.guildId)}','${escapeHtml(e.channelId)}')"
				title="${escapeHtml(e.guildName)} / ${escapeHtml(e.channelName)}">
				${icon}<span class="text-truncate" style="max-width:120px;">${escapeHtml(e.guildName)}</span>
				<small class="text-muted ms-1">#${escapeHtml(e.channelName)}</small>
			</button>`;
		}).join('');
	} catch (e) {}
}

function quickJoinVC(guildId, channelId) {
	document.getElementById('guildIdInput').value = guildId;
	document.getElementById('channelIdInput').value = channelId;
	botJoin();
}

document.addEventListener('DOMContentLoaded', () => {
	startPolling();
	refreshPlexAuth();
	loadVCHistory();
});
</script>
